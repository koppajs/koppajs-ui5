{
  "name": "@koppajs/koppajs-ui5",
  "version": "0.1.0",
  "description": "Official KoppaJS adapter for UI5 Web Components with explicit runtime configuration and a lightweight bridge layer.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/koppajs/koppajs-ui5"
  },
  "keywords": [
    "koppajs",
    "koppajs-module",
    "ui5",
    "ui5-web-components",
    "web-components",
    "custom-elements",
    "adapter",
    "integration",
    "component-library",
    "frontend",
    "typescript",
    "fiori"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=10.24.0"
  },
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "generate:ui5-manifests": "node ./scripts/generate-ui5-package-manifests.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "typecheck:declarations": "tsc --project tsconfig.build.json",
    "build": "pnpm run clean && pnpm run generate:ui5-manifests && pnpm run typecheck && vite build && pnpm run typecheck:declarations",
    "dev:example": "vite --config ./examples/basic-koppajs-app/vite.config.mjs --host",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "pnpm run lint -- --fix && pnpm run format",
    "lint:staged": "lint-staged --config lint-staged.config.mjs",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "pnpm run test:unit",
    "test:e2e": "playwright test",
    "check:package": "node ./scripts/check-package.mjs",
    "check:release-tag": "node ./scripts/check-release-tag.mjs",
    "test:package": "node ./scripts/test-package-consumer.mjs",
    "test": "pnpm run test:ci",
    "test:watch": "pnpm run test:unit:watch",
    "check": "pnpm run check:docs && pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test:ci && pnpm run build && pnpm run check:package && pnpm run test:package",
    "validate": "pnpm run check && pnpm run test:e2e",
    "check:docs": "node scripts/check-doc-contract.mjs",
    "prepare": "node -e \"const fs=require('node:fs'); const cp=require('node:child_process'); if(process.env.HUSKY==='0'){ console.log('Skipping husky install (HUSKY=0).'); process.exit(0); } if(!fs.existsSync('.git')){ console.log('Skipping husky install (no .git directory found).'); process.exit(0); } cp.execSync('pnpm exec husky',{stdio:'inherit'});\""
  },
  "peerDependencies": {
    "@koppajs/koppajs-core": "^3.0.2"
  },
  "dependencies": {
    "@ui5/webcomponents": "2.20.2",
    "@ui5/webcomponents-ai": "2.20.2",
    "@ui5/webcomponents-base": "2.20.2",
    "@ui5/webcomponents-compat": "2.20.2",
    "@ui5/webcomponents-fiori": "2.20.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@koppajs/koppajs-core": "^3.0.2",
    "@koppajs/koppajs-vite-plugin": "^1.0.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jsdom": "^27.2.0",
    "prettier": "^3.7.3",
    "typescript": "^5.7.2",
    "vite": "^7.2.6",
    "vitest": "^4.0.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "private": false
}
