#!/usr/bin/env sh
set -e

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm is required for commit message validation." >&2
  exit 1
fi

COMMIT_MSG_FILE="$1"

if grep -qE "^(Merge|Revert|fixup!|squash!)" "$COMMIT_MSG_FILE"; then
  exit 0
fi

pnpm exec commitlint --config commitlint.config.mjs --edit "$COMMIT_MSG_FILE"
